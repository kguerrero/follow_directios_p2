      "conversation": [
        {
          "invocation_id": "rec-001",
          "user_content": {
            "role": "user",
            "parts": [
              {
                "text": "I love cozy mysteries and want something comforting to read."
              }
            ]
          },
          "final_response": {
            "role": "model",
            "parts": [
              {
                "text": "Here are a few cozy mystery picks and what we logged for the recommendation request."
              }
            ]
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "recommend_books",
                "args": {
                  "patron": {
                    "name": "Alyssa",
                    "contact_email": "alyssa@example.com"
                  },
                  "favorite_genres": [
                    "mystery"
                  ],
                  "recent_reads": [
                    "The Thursday Murder Club"
                  ]
                }
              }
            ],
            "intermediate_responses": [
              [
                "library_root_agent",
                [
                  {
                    "text": "I'll route you to our reading concierge to collect preference details."
                  }
                ]
              ],
              [
                "book_recommendation_agent",
                [
                  {
                    "text": "Thanks for sharing the genres and recent reads—I'll send 3 picks your way."
                  }
                ]
              ]
            ]
          }
        }
      ],
      "session_input": {
        "app_name": "library_concierge",
        "user_id": "eval_user",
        "state": {}
      }
    },
